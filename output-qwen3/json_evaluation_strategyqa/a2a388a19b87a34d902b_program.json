  "knowledge_base": [
    "land_owners_elect_rulers(kingdom_of_hungary)",
    "ForAll([p1, p2], Implies(And(land_owners_elect_rulers(kingdom_of_hungary), is_land_owner(p1), is_ruler(p2), in_kingdom(p1, kingdom_of_hungary), in_kingdom(p2, kingdom_of_hungary)), elects(p1, p2)))"
  ],
  "verifications": [
    {
      "name": "Land owners elected rulers in Kingdom of Hungary",
      "exists": [
        {
          "name": "x",
          "sort": "Person"
        },
        {
          "name": "y",
          "sort": "Person"
        }
      ],
      "constraint": "And(is_land_owner(x), is_ruler(y), elects(x, y), in_kingdom(x, kingdom_of_hungary), in_kingdom(y, kingdom_of_hungary))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}