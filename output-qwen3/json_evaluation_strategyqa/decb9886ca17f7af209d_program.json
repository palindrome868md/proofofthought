{
  "sorts": [
    {
      "name": "Country",
      "type": "DeclareSort"
    },
    {
      "name": "Language",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "official_language",
      "domain": [
        "Country"
      ],
      "range": "Language"
    },
    {
      "name": "language_root",
      "domain": [
        "Language"
      ],
      "range": "Language"
    },
    {
