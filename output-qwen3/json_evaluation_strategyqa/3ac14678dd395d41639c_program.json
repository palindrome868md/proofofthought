  ],
  "rules": [],
  "verifications": [
    {
      "name": "Eleventh-grader Medicare Eligibility",
      "exists": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "constraint": "And(is_eleventh_grader(p), eligible_for_medicare(p))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
