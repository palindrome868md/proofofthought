  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "applicant",
        "partner"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "hours_of_care(applicant) == 30",
    "earnings_per_week(applicant) == 115",
    "partner_receives_qualifying_benefit(applicant)",
    "lives_in_uk(applicant)",
    "age(applicant) >= 16",
    "Not(in_full_time_education(applicant))",
    "ForAll([p], Implies(And(hours_of_care(p) >= 35, earnings_per_week(p) <= 128, partner_receives_qualifying_benefit(p), lives_in_uk(p), age(p) >= 16, Not(in_full_time_education(p))), eligible_for_carers_allowance(p)))"
  ],
  "verifications": [
    {
      "name": "Can applicant claim Carers Allowance",
      "constraint": "eligible_for_carers_allowance(applicant)"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}