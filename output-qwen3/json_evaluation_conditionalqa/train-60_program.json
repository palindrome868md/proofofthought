    "ForAll([p], Implies(And(is_widow(p), spouse_died_in_service(p), Not(spouse_died_before_april_2005(p))), eligible_afcs(p)))"
  ],
  "verifications": [
    {
      "name": "Can aunt claim War Widow Pension",
      "constraint": "eligible_war_widow_pension(aunt)"
