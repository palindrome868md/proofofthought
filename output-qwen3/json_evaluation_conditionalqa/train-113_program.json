  ],
  "knowledge_base": [
    "age(claimant) == 54",
    "months_since_diagnosis(claimant) == 6",
    "has_mesothelioma(claimant)",
    "exposed_in_uk(claimant)",
    "Not(employer_traced(claimant))",
    "Not(insurer_traced(claimant))",
    "Not(civil_claim_made(claimant))",
    "Not(damages_received(claimant))",
    "ForAll([p], Implies(And(has_mesothelioma(p), exposed_in_uk(p), Not(employer_traced(p)), Not(insurer_traced(p)), Not(civil_claim_made(p)), Not(damages_received(p))), eligible_for_dmps(p)))",
    "ForAll([p], Implies(And(has_mesothelioma(p), exposed_in_uk(p), months_since_diagnosis(p) <= 12, Not(damages_received(p))), eligible_for_2008_scheme(p)))",
    "ForAll([p], Implies(Or(eligible_for_dmps(p), eligible_for_2008_scheme(p)), eligible_for_state_compensation(p)))"
  ],
  "verifications": [
    {
      "name": "Claimant eligible for state compensation despite untraced employer",
      "constraint": "eligible_for_state_compensation(claimant)"
    }
