      ],
      "range": "IntSort"
    },
    {
      "name": "has_gender_certificate_from",
      "domain": [
        "Person",
        "Country"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_approved_country",
      "domain": [
        "Country"
      ],
      "range": "BoolSort"
    },
    {
      "name": "lived_in_acquired_gender_years",
      "domain": [
        "Person"
      ],
      "range": "IntSort"
    },
    {
      "name": "resides_in_uk",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "intends_to_live_in_acquired_gender",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "has_gender_dysphoria_diagnosis",
      "domain": [
