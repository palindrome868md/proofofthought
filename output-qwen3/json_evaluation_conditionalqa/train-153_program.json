{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    },
    {
      "name": "Location",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "is_registered_blind",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "has_blindness_certificate",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "cannot_do_eyesight_work",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "lives_in_england_wales",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "lives_in_scotland_ni",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_eligible_for_bpa",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "has_large_savings",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_partially_blind",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
