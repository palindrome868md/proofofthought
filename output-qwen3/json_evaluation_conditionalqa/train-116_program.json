      ]
    },
    "benefits": {
      "sort": "BenefitType",
      "members": [
        "IncomeSupport",
        "JSA",
        "ESA",
        "PensionCredit",
        "UniversalCredit"
      ]
    },
    "items": {
      "sort": "ItemType",
      "members": [
        "Furniture",
        "WhiteGoods",
        "Clothes",
        "Rent",
        "Moving",
        "Maintenance",
        "Travel",
        "Job",
        "Maternity",
        "Funeral",
