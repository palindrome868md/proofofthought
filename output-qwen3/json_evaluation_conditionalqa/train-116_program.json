  "variables": [
    {
      "name": "p",
      "sort": "Person"
    },
    {
      "name": "b",
      "sort": "BenefitType"
    },
    {
      "name": "i",
      "sort": "ItemType"
    }
  ],
  "knowledge_base": [
    "needs(user, Furniture)",
    "needs(user, WhiteGoods)",
    "moved(user)",
    "savings(user) == 500",
    "debt(user) == 0",
    "on_industrial_action(user) == False",
    "Not(claims(user, IncomeSupport))",
    "Not(claims(user, JSA))",
    "Not(claims(user, ESA))",
    "Not(claims(user, PensionCredit))",
    "Not(claims(user, UniversalCredit))",
    "ForAll([p], has_valid_reason(p) == Or(needs(p, Furniture), needs(p, WhiteGoods), needs(p, Clothes), needs(p, Rent), needs(p, Moving), needs(p, Maintenance), needs(p, Travel), needs(p, Job), needs(p, Maternity), needs(p, Funeral), needs(p, HirePurchase), needs(p, LoanRepayment), moved(p)))",
    "ForAll([p], has_qualifying_benefit(p) == Or(claims(p, IncomeSupport), claims(p, JSA), claims(p, ESA), claims(p, PensionCredit)))",
    "ForAll([p], is_excluded(p) == Or(claims(p, UniversalCredit), on_industrial_action(p), debt(p) > 1500))",
    "ForAll([p], has_ok_savings(p) == savings(p) <= 1000)",
    "ForAll([p], eligible(p) == And(has_valid_reason(p), has_qualifying_benefit(p), Not(is_excluded(p)), has_ok_savings(p)))"
  ],
  "verifications": [
    {
      "name": "Check Eligibility",
      "constraint": "eligible(user)"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}