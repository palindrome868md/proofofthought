    "is_disabled(aunt) == True",
    "owns_property(aunt, her_home) == True",
    "needs_heating_repair(her_home) == True",
    "needs_lighting_repair(her_home) == True",
    "ForAll([p, prop, g], Implies(And(is_disabled(p), owns_property(p, prop), work_is_necessary(prop, g), work_is_reasonable(prop)), eligible_for_grant(p, prop, g)))",
    "ForAll([prop, g], Implies(Or(needs_heating_repair(prop), needs_lighting_repair(prop)), work_is_necessary(prop, g)))",
    "work_is_reasonable(her_home) == True"
  ],
  "verifications": [
    {
      "name": "Is aunt eligible for disabled facilities grant",
      "constraint": "eligible_for_grant(aunt, her_home, disabled_facilities_grant)"
