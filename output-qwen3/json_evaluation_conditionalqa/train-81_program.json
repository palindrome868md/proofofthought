    "has_walking_difficulty(child)",
    "meets_residence(child)",
    "meets_disability_duration(child)",
    "is_step_parent(step_father, child)",
    "Not(is_biological_parent(step_father, child))",
    "ForAll([p, c], Implies(is_step_parent(p, c), looks_after_as_parent(p, c)))",
    "ForAll([p, c], Implies(And(age(c) < 16, has_walking_difficulty(c), meets_residence(c), meets_disability_duration(c), Or(is_biological_parent(p, c), looks_after_as_parent(p, c))), can_claim_dla(p, c)))"
  ],
