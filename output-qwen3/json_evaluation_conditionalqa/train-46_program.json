{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    },
    {
      "name": "Property",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "is_disabled",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_tenant",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "owns_property",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "intends_to_live_years",
      "domain": [
        "Person"
      ],
      "range": "IntSort"
    },
    {
      "name": "meets_residency_requirement",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "applicant"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "is_disabled(applicant) == True",
    "is_tenant(applicant) == True",
    "owns_property(applicant) == False",
    "intends_to_live_years(applicant) == 3",
    "ForAll([p], Implies(intends_to_live_years(p) >= 5, meets_residency_requirement(p)))",
    "ForAll([p], Implies(intends_to_live_years(p) < 5, Not(meets_residency_requirement(p))))",
    "ForAll([p], Implies(And(is_disabled(p), Or(is_tenant(p), owns_property(p)), meets_residency_requirement(p)), True))"
  ],
  "verifications": [
    {
      "name": "Can applicant apply for Disabled Facilities Grant",
      "constraint": "And(is_disabled(applicant), is_tenant(applicant), meets_residency_requirement(applicant))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}