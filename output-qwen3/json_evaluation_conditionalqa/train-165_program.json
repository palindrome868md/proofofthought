  "knowledge_base": [
    "lpa_registration_cost() == 82",
    "lives_in_england(the_user)",
    "age(the_user) == 57",
    "on_benefit(the_user, income_support)",
    "ForAll([p], Implies(on_benefit(p, income_support), eligible_for_exemption(p)))",
