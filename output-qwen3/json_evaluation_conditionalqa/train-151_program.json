  "knowledge_base": [
    "has_dementia(grandmother)",
    "has_estate(grandmother)",
    "Not(made_existing_will(grandmother))",
    "is_family_member(grandchild, grandmother)",
    "ForAll([p], Implies(has_dementia(p), lacks_testamentary_capacity(p)))",
    "ForAll([p, q], Implies(And(lacks_testamentary_capacity(p), is_family_member(q, p), has_estate(p), Not(made_existing_will(p))), can_apply_for_statutory_will(q, p)))",
    "ForAll([p, q], Implies(can_apply_for_statutory_will(q, p), acts_in_best_interest(q, p)))",
    "ForAll([p, q], Implies(And(can_apply_for_statutory_will(q, p), acts_in_best_interest(q, p)), can_make_will_on_behalf(q, p)))"
  ],
  "verifications": [
    {
      "name": "Can grandchild make statutory will for grandmother",
      "constraint": "can_make_will_on_behalf(grandchild, grandmother)"
    }
