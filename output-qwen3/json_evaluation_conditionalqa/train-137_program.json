{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "earns",
      "domain": [
        "Person"
      ],
      "range": "IntSort"
    },
    {
      "name": "high_income_tax_applies",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "tax_waived",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "taxpayer"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "ForAll([p], Implies(earns(p) > 50000, high_income_tax_applies(p)))",
    "ForAll([p], Implies(high_income_tax_applies(p), Not(tax_waived(p))))"
  ],
  "verifications": [
    {
      "name": "Can tax be waived when earning over 50000",
      "constraint": "And(earns(taxpayer) > 50000, tax_waived(taxpayer))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}