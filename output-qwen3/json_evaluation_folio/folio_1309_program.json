  "knowledge_base": [
    "ForAll([h], Implies(can_control_breath(h), has_functional_brainstem(h)))",
    "ForAll([h], Implies(can_swim(h), can_control_breath(h)))",
    "ForAll([h], Or(can_swim(h), can_walk(h)))",
    "ForAll([h], Implies(can_walk(h), can_stand_on_ground(h)))",
    "ForAll([h], Implies(has_functional_brainstem(h), can_control_balance(h)))",
    "ForAll([h], Implies(can_stand_on_ground(h), has_functional_leg_muscles(h)))",
    "can_control_balance(George) == True",
    "can_swim(George) == True",
    "can_walk(Archie) == has_functional_brainstem(Archie)"
  ],
  "verifications": [
    {
      "name": "Archie Statement Verification",
      "constraint": "And(Not(can_control_balance(Archie)), Not(has_functional_leg_muscles(Archie)))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
