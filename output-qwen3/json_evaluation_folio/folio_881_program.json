{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "is_athlete",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "exercises",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_pro_bball_player",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_nba_player",
      "domain": [
        "Person"
      ],
