    "ForAll([p], Implies(AttendsWedding(p), Or(GettingMarried(p), KnowsGettingMarried(p))))",
    "ForAll([p], Implies(Or(IsPreteen(p), IsYoungChild(p)), Not(Or(GettingMarried(p), KnowsGettingMarried(p)))))",
    "ForAll([p], Implies(EnjoysCelebrating(p), AttendsWedding(p)))",
    "ForAll([p], Implies(FondOfLargeGroups(p), EnjoysCelebrating(p)))",
    "ForAll([p], Implies(And(Outgoing(p), Spirited(p)), FondOfLargeGroups(p)))",
    "Implies(Not(And(Or(IsPreteen(Carol), IsYoungChild(Carol)), AttendsWedding(Carol))), Not(Or(GettingMarried(Carol), KnowsGettingMarried(Carol))))"
