  ],
  "knowledge_base": [
    "is_fish(stonefish)",
    "ForAll([p], Implies(stepped_on(p, stonefish), stings(stonefish, p)))",
    "ForAll([p], Implies(And(stings(stonefish, p), Not(treated(p))), causes_death(stonefish, p)))",
    "Exists([f, p], And(is_fish(f), stings(f, p)))"
  ],
  "verifications": [
    {
      "name": "Some fish stings cause death if not treated",
      "exists": [
        {
          "name": "f",
          "sort": "Animal"
        }
      ],
      "constraint": "And(is_fish(f), ForAll([p], Implies(And(stings(f, p), Not(treated(p))), causes_death(f, p))))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}