  "knowledge_base": [
    "ForAll([p, loc], Implies(rents_car(p, loc), spends_money(p)))",
    "Implies(goes_to(sarah, vermont), drives(sarah, vermont))",
    "ForAll([p, loc], Implies(And(drives(p, loc), Not(owns_car(p))), Or(borrows_car(p, loc), rents_car(p, loc))))",
    "Not(owns_car(sarah))",
    "ForAll([loc], Implies(goes_camping(sarah, loc), Not(borrows_car(sarah, loc))))",
    "goes_camping(sarah, vermont)",
    "ForAll([p, loc], Implies(goes_camping(p, loc), goes_to(p, loc)))"
  ],
  "verifications": [
    {
      "name": "Sarah Spends Money",
      "constraint": "spends_money(sarah)"
