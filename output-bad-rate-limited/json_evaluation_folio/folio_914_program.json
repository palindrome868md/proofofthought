{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "spends_most_time_on_sports",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "professional_athlete",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "olympic_gold_medalist",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "full_time_scientist",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "nobel_physics_laureate",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "amy"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "ForAll([p], Implies(professional_athlete(p), spends_most_time_on_sports(p)))",
    "ForAll([p], Implies(olympic_gold_medalist(p), professional_athlete(p)))",
    "ForAll([p], Implies(full_time_scientist(p), Not(spends_most_time_on_sports(p))))",
    "ForAll([p], Implies(nobel_physics_laureate(p), full_time_scientist(p)))",
    "Or(spends_most_time_on_sports(amy), olympic_gold_medalist(amy))",
    "Implies(Not(nobel_physics_laureate(amy)), Not(olympic_gold_medalist(amy)))"
  ],
  "verifications": [
    {
      "name": "Amy is neither full-time scientist nor Olympic gold medalist",
      "constraint": "And(Not(full_time_scientist(amy)), Not(olympic_gold_medalist(amy)))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}