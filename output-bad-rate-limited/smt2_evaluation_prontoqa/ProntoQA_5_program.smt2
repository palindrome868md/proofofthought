(set-logic ALL)

; Sort
(declare-sort Person 0)

; Predicates
(declare-fun Rompuse (Person) Bool)
(declare-fun Zumpus (Person) Bool)
(declare-fun Numpus (Person) Bool)
(declare-fun Tumpus (Person) Bool)
(declare-fun Yumpus (Person) Bool)
(declare-fun Jompus (Person) Bool)
(declare-fun Wumpus (Person) Bool)
(declare-fun Vumpus (Person) Bool)
(declare-fun Impuse (Person) Bool)
(declare-fun Dumpuse (Person) Bool)
(declare-fun Dull (Person) Bool)
(declare-fun Sour (Person) Bool)
(declare-fun Happy (Person) Bool)
(declare-fun Temperate (Person) Bool)
(declare-fun Large (Person) Bool)
(declare-fun Earthy (Person) Bool)
(declare-fun Blue (Person) Bool)
(declare-fun Mean (Person) Bool)

; Constant
(declare-const Alex Person)

; Facts
(assert (Numpus Alex))

; Axioms (universal)
(assert (forall ((p Person))
  (=> (Rompuse p) (Mean p))))
(assert (forall ((p Person))
  (=> (Rompuse p) (Zumpus p))))
(assert (forall ((p Person))
  (=> (Zumpus p) (not (Happy p)))))
(assert (forall ((p Person))
  (=> (Zumpus p) (Numpus p))))
(assert (forall ((p Person))
  (=> (Numpus p) (not (Temperate p)))))
(assert (forall ((p Person))
  (=> (Numpus p) (Tumpus p))))
(assert (forall ((p Person))
  (=> (Tumpus p) (not (Large p)))))
(assert (forall ((p Person))
  (=> (Tumpus p) (Yumpus p))))
(assert (forall ((p Person))
  (=> (Yumpus p) (Earthy p))))
(assert (forall ((p Person))
  (=> (Yumpus p) (Jompus p))))
(assert (forall ((p Person))
  (=> (Jompus p) (Blue p))))
(assert (forall ((p Person))
  (=> (Jompus p) (Wumpus p))))
(assert (forall ((p Person))
  (=> (Wumpus p) (not (Dull p)))))
(assert (forall ((p Person))
  (=> (Wumpus p) (Impuse p))))
(assert (forall ((p Person))
  (=> (Impuse p) (Sour p))))
(assert (forall ((p Person))
  (=> (Impuse p) (Dumpuse p))))
(assert (forall ((p Person))
  (=> (Vumpus p) (Dull p))))

; Query: Is "Alex is not dull" true?
(assert (not (Dull Alex)))

(check-sat)
(get-model)