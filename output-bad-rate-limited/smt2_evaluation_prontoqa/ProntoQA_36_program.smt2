(declare-sort Person 0)

(declare-fun jompus (Person) Bool)
(declare-fun bright (Person) Bool)
(declare-fun wumpus (Person) Bool)
(declare-fun wooden (Person) Bool)
(declare-fun yumpus (Person) Bool)
(declare-fun amenable (Person) Bool)
(declare-fun impuses (Person) Bool)
(declare-fun temperate (Person) Bool)
(declare-fun tumpus (Person) Bool)
(declare-fun shy (Person) Bool)
(declare-fun rompus (Person) Bool)
(declare-fun numpus (Person) Bool)
(declare-fun fruity (Person) Bool)
(declare-fun dumpus (Person) Bool)
(declare-fun vumpus (Person) Bool)
(declare-fun small (Person) Bool)

(declare-const Sally Person)

; Knowledge base
(assert (jompus Sally))
(assert (forall ((p Person)) (=> (jompus p) (bright p))))
(assert (forall ((p Person)) (=> (jompus p) (wumpus p))))
(assert (forall ((p Person)) (=> (wumpus p) (wooden p))))
(assert (forall ((p Person)) (=> (wumpus p) (yumpus p))))
(assert (forall ((p Person)) (=> (yumpus p) (amenable p))))
(assert (forall ((p Person)) (=> (yumpus p) (impuses p))))
(assert (forall ((p Person)) (=> (impuses p) (temperate p))))
(assert (forall ((p Person)) (=> (impuses p) (tumpus p))))
(assert (forall ((p Person)) (=> (tumpus p) (shy p))))
(assert (forall ((p Person)) (=> (tumpus p) (rompus p))))
(assert (forall ((p Person)) (=> (rompus p) (not (small p)))))
(assert (forall ((p Person)) (=> (rompus p) (numpus p))))
(assert (forall ((p Person)) (=> (numpus p) (fruity p))))
(assert (forall ((p Person)) (=> (dumpus p) (not (shy p))))))
(assert (forall ((p Person)) (=> (numpus p) (vumpus p))))

; Test: Is Sally shy?
(assert (shy Sally))

(check-sat)
(get-model)