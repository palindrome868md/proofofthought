  "verifications": [
    {
      "name": "Can make legally binding contract without court",
      "exists": [
        {
          "name": "p",
          "sort": "Person"
        },
        {
          "name": "e",
          "sort": "Person"
        }
      ],
      "constraint": "And(agree_evenly(p, e), consent_order_legally_binding(p, e), Not(court_hearing_needed(p, e)))"
