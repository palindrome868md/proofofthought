      "implies": {
        "antecedent": "And(stopped_income_support(p), received_income_support_26_weeks(p), work_full_time(p), work_expected_at_least_5(p), claimed_mortgage_interest(p))",
        "consequent": "eligible_for_miro(p)"
      }
    }
