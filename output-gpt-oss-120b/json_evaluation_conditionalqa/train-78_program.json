{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    },
    {
      "name": "Country",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "is_disabled",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "owns_property",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "lives_in_country",
      "domain": [
        "Person",
        "Country"
      ],
      "range": "BoolSort"
    },
    {
      "name": "intends_to_live",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "me",
        "wife"
      ]
    },
    "countries": {
      "sort": "Country",
      "members": [
        "england"
      ]
    },
    "savings": {
      "sort": "IntSort",
      "members": [
        "savings_amount"
      ]
    }
  },
  "variables": [],
  "knowledge_base": [
    "is_disabled(wife)",
    "owns_property(me)",
    "lives_in_country(me, england)",
    "lives_in_country(wife, england)",
    "intends_to_live(me)",
    "intends_to_live(wife)",
    "savings_amount == 5000"
  ],
  "verifications": [
    {
      "name": "Can apply for Disabled Facilities Grant",
      "exists": [
        {
          "name": "d",
          "sort": "Person"
        }
      ],
      "constraint": "And(is_disabled(d), owns_property(d), lives_in_country(d, england), intends_to_live(d), savings_amount <= 6000)"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}