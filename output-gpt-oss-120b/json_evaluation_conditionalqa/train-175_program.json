{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "owe_budgeting_loans",
      "domain": [
        "Person"
      ],
      "range": "IntSort"
    },
    {
      "name": "can_borrow_more",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "applicant"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "owe_budgeting_loans(applicant) == 1600",
    "ForAll([p], Implies(owe_budgeting_loans(p) > 1500, Not(can_borrow_more(p))))"
  ],
  "verifications": [
    {
      "name": "Can borrow more with existing debt",
      "constraint": "can_borrow_more(applicant)"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}