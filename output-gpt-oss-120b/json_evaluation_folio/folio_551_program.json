  },
  "knowledge_base": [
    "ForAll([t1, t2], Implies(more_points(t1, t2), ranks_higher(t1, t2)))",
    "ForAll([t1, t2], Implies(And(Not(more_points(t1, t2)), Not(more_points(t2, t1)), more_points_between(t1, t2)), ranks_higher(t1, t2)))",
    "more_points(real_madrid, barcelona)",
    "Not(more_points_between(real_madrid, barcelona))",
    "Not(more_points_between(barcelona, real_madrid))"
  ],
  "verifications": [
    {
      "name": "Barcelona ranks higher than Real Madrid",
      "constraint": "ranks_higher(barcelona, real_madrid)"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
