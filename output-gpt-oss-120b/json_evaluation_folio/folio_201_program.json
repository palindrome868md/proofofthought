      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "directed",
      "domain": [
        "Person",
        "Film"
      ],
      "range": "BoolSort"
    },
    {
      "name": "documentary",
      "domain": [
        "Film"
      ],
      "range": "BoolSort"
    },
    {
      "name": "film",
      "domain": [
        "Film"
      ],
      "range": "BoolSort"
    },
    {
      "name": "filmmaker",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_from",
      "domain": [
        "Person",
        "City"
      ],
      "range": "BoolSort"
    },
    {
      "name": "city_in_country",
      "domain": [
        "City",
        "Country"
      ],
      "range": "BoolSort"
    },
    {
      "name": "from_country",
      "domain": [
        "Person",
