      ]
    }
  },
  "variables": [
    {
      "name": "x",
      "sort": "Thing"
    }
  ],
  "knowledge_base": [
    "ForAll([x], Implies(biodegradable(x), env_friendly(x)))",
    "ForAll([x], Implies(woodware(x), biodegradable(x)))",
    "ForAll([x], Implies(paper(x), woodware(x)))",
    "ForAll([x], Not(And(good(x), bad(x))))",
    "ForAll([x], Implies(env_friendly(x), good(x)))",
    "Or(paper(worksheet), env_friendly(worksheet))"
  ],
  "verifications": [
    {
      "name": "WorksheetIsBad",
      "constraint": "bad(worksheet)"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
