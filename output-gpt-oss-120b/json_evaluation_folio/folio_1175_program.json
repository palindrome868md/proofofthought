    "ForAll([m], Implies(in_library(m), made_before_2010(m)))",
    "Or(in_library(L2021), has_typec(L2021))",
    "Or(And(made_before_2010(L2021), made_by(L2021, LG)), And(Not(made_before_2010(L2021)), Not(made_by(L2021, LG))))"
  ],
  "verifications": [
    {
      "name": "L2021_has_typec_or_made_by_LG",
      "constraint": "Not(Or(has_typec(L2021), made_by(L2021, LG)))"
