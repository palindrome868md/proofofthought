{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "works_at_meta",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "high_income",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "takes_bus",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "drives",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "has_car",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_student",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
