  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "james"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "ForAll([p], Implies(works_at_meta(p), high_income(p)))",
    "ForAll([p], Implies(high_income(p), Not(takes_bus(p))))",
    "ForAll([p], Or(takes_bus(p), drives(p)))",
    "ForAll([p], Implies(has_car(p), drives(p)))",
    "ForAll([p], Implies(is_student(p), Not(drives(p))))",
    "Or(has_car(james), works_at_meta(james))"
  ],
  "verifications": [
    {
      "name": "JamesIsStudent",
      "constraint": "is_student(james)"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}