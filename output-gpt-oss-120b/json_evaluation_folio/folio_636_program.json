  "rules": [
    {
      "name": "NoSeatForPortlandSupporters",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "implies": {
        "antecedent": "supported_portland_whigs(p)",
        "consequent": "Not(has_seat(p))"
      }
    },
    {
      "name": "SeatIfSatInCommons",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "implies": {
        "antecedent": "sat_in_house_of_commons(p)",
        "consequent": "has_seat(p)"
      }
    }
  ],
  "verifications": [
    {
      "name": "WilliamDidNotGetSeat",
      "constraint": "Not(has_seat(william_dickinson))"
    }
  ],
