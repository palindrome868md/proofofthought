  "knowledge_base": [
    "ForAll([f], Implies(And(is_red(f), grows_in(f, ben_yard)), contains_vitC(f)))",
    "ForAll([f], Implies(And(is_apple(f), grows_in(f, ben_yard)), is_red(f)))",
    "ForAll([f], Implies(And(grows_in(f, ben_yard), contains_vitC(f)), is_healthy(f)))",
    "ForAll([f], Implies(And(grows_in(f, ben_yard), is_healthy(f)), Not(on_warning_list(f))))",
    "grows_in(cherries, ben_yard)",
    "Implies(And(Not(is_apple(cherries)), Not(is_healthy(cherries))), is_red(cherries))"
  ],
  "verifications": [
    {
      "name": "Cherries vitamin C or warning list",
      "constraint": "Not(Or(contains_vitC(cherries), on_warning_list(cherries)))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
