    "ForAll([x], Implies(And(IsMulticellular(x), IsAnimal(x)), Not(IsBacteria(x))))",
    "ForAll([x], Implies(And(IsAnimal(x), IsDisplayed(x)), IsMulticellular(x)))",
    "IsDisplayed(sea_eel)",
    "Or(IsEel(sea_eel), IsAnimal(sea_eel), Not(IsPlant(sea_eel)))"
