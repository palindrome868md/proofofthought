    "ForAll([p], Implies(enjoys_celebrating(p), attends_wedding(p)))",
    "ForAll([p], Implies(fond_large(p), enjoys_celebrating(p)))",
    "ForAll([p], Implies(outgoing_spirited(p), fond_large(p)))",
    "Implies(And(Not(preteen_young(carol)), attends_wedding(carol)), And(Not(getting_married(carol)), Not(knows_getting_married(carol))))"
