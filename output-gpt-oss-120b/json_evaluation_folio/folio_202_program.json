  "rules": [
    {
      "name": "Filmmaker rule",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        },
        {
          "name": "f",
          "sort": "Film"
        }
      ],
      "implies": {
        "antecedent": "Directed(p, f)",
        "consequent": "IsFilmmaker(p)"
      }
    },
    {
      "name": "Documentary is a Film",
      "forall": [
        {
          "name": "f",
          "sort": "Film"
        }
      ],
      "implies": {
        "antecedent": "Documentary(f)",
        "consequent": "Film(f)"
      }
    }
  ],
  "verifications": [
    {
      "name": "Miss Americana not directed by a filmmaker from Kirkland",
      "constraint": "Not(And(Directed(Lana_Wilson, Miss_Americana), IsFilmmaker(Lana_Wilson), From(Lana_Wilson, Kirkland)))"
    }
  ],
