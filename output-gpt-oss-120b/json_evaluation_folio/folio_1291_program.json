    "ForAll([p], Or(seasoned_interviewer(p), has_human_rights(p)))",
    "ForAll([p], Implies(has_human_rights(p), entitled(p)))",
    "ForAll([p], Implies(knows_how_queue(p), knows_about_fifo(p)))",
    "ForAll([p], Implies(entitled(p), cannot_be_deprived_without_due_process(p)))",
    "Or(entitled(jack), has_human_rights(jack), knows_about_fifo(jack))"
  ],
  "verifications": [
    {
      "name": "JackCanBeDeprivedWithoutDueProcess",
      "constraint": "Not(cannot_be_deprived_without_due_process(jack))"
