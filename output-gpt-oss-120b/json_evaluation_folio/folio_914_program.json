{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "spends_most_time_on_sports",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "professional_athlete",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "olympic_gold_winner",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "full_time_scientist",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "nobel_physics_laureate",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "amy"
      ]
    }
  },
  "variables": [
    {
      "name": "x",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "ForAll([x], Implies(professional_athlete(x), spends_most_time_on_sports(x)))",
    "ForAll([x], Implies(olympic_gold_winner(x), professional_athlete(x)))",
    "ForAll([x], Implies(full_time_scientist(x), Not(spends_most_time_on_sports(x))))",
    "ForAll([x], Implies(nobel_physics_laureate(x), full_time_scientist(x)))",
    "Or(spends_most_time_on_sports(amy), olympic_gold_winner(amy))",
    "Implies(Not(nobel_physics_laureate(amy)), Not(olympic_gold_winner(amy)))"
  ],
  "verifications": [
    {
      "name": "Amy neither full-time scientist nor Olympic gold medal winner",
      "constraint": "And(Not(full_time_scientist(amy)), Not(olympic_gold_winner(amy)))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}