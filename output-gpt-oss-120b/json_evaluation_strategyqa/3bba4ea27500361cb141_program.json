      ]
    },
    "tunnels": {
      "sort": "Tunnel",
      "members": [
        "lincoln_tunnel"
      ]
    }
  },
  "variables": [
    {
      "name": "v",
      "sort": "Vehicle"
    }
  ],
  "knowledge_base": [
    {
