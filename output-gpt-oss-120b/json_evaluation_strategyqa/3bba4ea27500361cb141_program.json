{
  "sorts": [
    {
      "name": "Vehicle",
      "type": "DeclareSort"
    },
    {
      "name": "Tunnel",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "is_cruise_boat",
      "domain": [
        "Vehicle"
      ],
      "range": "BoolSort"
    },
    {
      "name": "traverses",
      "domain": [
        "Vehicle",
        "Tunnel"
      ],
