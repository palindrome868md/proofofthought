{
  "sorts": [
    {
      "name": "City",
      "type": "DeclareSort"
    },
    {
      "name": "Person",
      "type": "DeclareSort"
    },
    {
      "name": "Plant",
      "type": "DeclareSort"
    },
    {
      "name": "PlantName",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "lives_in",
      "domain": [
        "Person",
        "City"
      ],
      "range": "BoolSort"
    },
    {
      "name": "refers_as",
      "domain": [
        "Person",
        "Plant",
        "PlantName"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "cities": {
      "sort": "City",
      "members": [
        "mumbai"
      ]
    },
    "plants": {
      "sort": "Plant",
      "members": [
        "solanum_melongena"
      ]
    },
    "plant_names": {
      "sort": "PlantName",
      "members": [
        "eggplant",
        "brinjal"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "ForAll([p], Implies(lives_in(p, mumbai), Not(refers_as(p, solanum_melongena, eggplant))))",
    "ForAll([p], Implies(lives_in(p, mumbai), refers_as(p, solanum_melongena, brinjal)))",
    "Exists([p], lives_in(p, mumbai))"
  ],
  "verifications": [
    {
      "name": "Someone in Mumbai calls eggplant eggplant",
      "exists": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "constraint": "And(lives_in(p, mumbai), refers_as(p, solanum_melongena, eggplant))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}