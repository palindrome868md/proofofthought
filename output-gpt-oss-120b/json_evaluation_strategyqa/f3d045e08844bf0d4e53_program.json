{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    },
    {
      "name": "Artwork",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "sold_cc_license",
      "domain": [
        "Person",
        "Artwork"
      ],
      "range": "BoolSort"
    },
    {
      "name": "public_domain",
      "domain": [
        "Artwork"
      ],
      "range": "BoolSort"
    },
    {
      "name": "ripped_off",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "john_doe"
      ]
    },
    "artworks": {
      "sort": "Artwork",
      "members": [
        "birth_of_venus"
      ]
    }
  },
  "variables": [],
  "knowledge_base": [
    "public_domain(birth_of_venus)",
    "sold_cc_license(john_doe, birth_of_venus)"
  ],
  "rules": [
    {
      "name": "Ripoff Rule",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        },
        {
          "name": "a",
          "sort": "Artwork"
        }
      ],
      "implies": {
        "antecedent": "And(sold_cc_license(p, a), public_domain(a))",
        "consequent": "ripped_off(p)"
      }
    }
  ],
  "verifications": [
    {
      "name": "John Doe was ripped off",
      "constraint": "ripped_off(john_doe)"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}