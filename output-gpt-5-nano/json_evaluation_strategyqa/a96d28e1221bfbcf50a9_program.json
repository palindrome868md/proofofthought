      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "decline_CT_scan",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {},
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
