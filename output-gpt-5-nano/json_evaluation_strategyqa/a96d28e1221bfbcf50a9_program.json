    "ForAll([p], Implies(Not(has_insurance(p)), decline_CT_scan(p)))"
  ],
  "rules": [],
  "verifications": [
    {
      "name": "Uninsured are more likely to decline CT scan",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "implies": {
        "antecedent": "Not(has_insurance(p))",
        "consequent": "decline_CT_scan(p)"
