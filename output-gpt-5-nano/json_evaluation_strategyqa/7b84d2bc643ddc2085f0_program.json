      ]
    },
    "locations": {
      "sort": "Location",
      "members": [
        "lincoln_tunnel"
      ]
    }
  },
  "variables": [],
  "knowledge_base": [
    "is_flooded(lincoln_tunnel)",
    "can_sail_through(noahs_ark, lincoln_tunnel)"
