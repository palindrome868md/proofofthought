{
  "sorts": [
    {
      "name": "Vessel",
      "type": "DeclareSort"
    },
    {
      "name": "Location",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "can_sail_through",
      "domain": [
        "Vessel",
        "Location"
      ],
      "range": "BoolSort"
    },
    {
      "name": "is_flooded",
      "domain": [
        "Location"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
