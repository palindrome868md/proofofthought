  "verifications": [
    {
      "name": "Ark can sail flooded Lincoln Tunnel",
      "exists": [
        {
          "name": "loc",
          "sort": "Location"
        }
      ],
      "constraint": "And(loc == lincoln_tunnel, is_flooded(loc), can_sail_through(noahs_ark, loc))"
