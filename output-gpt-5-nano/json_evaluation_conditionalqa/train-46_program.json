  "verifications": [
    {
      "name": "Can I apply for Disabled Facilities Grant given I plan to live 3 years?",
      "exists": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "constraint": "And(is_disabled(p), is_tenant(p), intends_to_live_years(p) == 3, can_apply_DFG(p))"
