  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "james"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "ForAll([p], Implies(works_at_Meta(p), high_income(p)))",
    "ForAll([p], Implies(high_income(p), Not(takes_bus(p))))",
    "ForAll([p], And(Or(takes_bus(p), drives(p)), Not(And(takes_bus(p), drives(p)))))",
    "ForAll([p], Implies(has_car(p), drives(p)))",
    "ForAll([p], Implies(student(p), Not(drives(p))))",
    "Or(has_car(james), works_at_Meta(james))"
  ],
  "verifications": [
    {
      "name": "James Drives or is a Student",
      "constraint": "Or(drives(james), student(james))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}