      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "exercise",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "professional_basketball_player",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "nba_player",
      "domain": [
        "Person"
      ],
