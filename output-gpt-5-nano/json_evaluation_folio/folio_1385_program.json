      ],
      "implies": {
        "antecedent": "And(is_social_media(a), has_chat(a))",
        "consequent": "is_software(a)"
      }
    },
    {
      "name": "Software and social imply computer program",
      "forall": [
        {
          "name": "a",
          "sort": "App"
        }
      ],
      "implies": {
        "antecedent": "And(is_software(a), is_social_media(a))",
        "consequent": "is_computer_program(a)"
      }
    }
