  "knowledge_base": [
    {
      "name": "Kids are Young",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "implies": {
        "antecedent": "kid(p)",
        "consequent": "young(p)"
      }
    },
    {
      "name": "Toddlers are Kids",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "implies": {
        "antecedent": "toddler(p)",
        "consequent": "kid(p)"
      }
    },
    {
      "name": "Young implies Not Elderly",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "implies": {
        "antecedent": "young(p)",
        "consequent": "Not(elderly(p))"
      }
    },
    {
      "name": "Pirates are Seafarers",
      "forall": [
        {
          "name": "p",
          "sort": "Person"
        }
      ],
      "implies": {
        "antecedent": "pirate(p)",
        "consequent": "seafarer(p)"
      }
    },
    "Implies(Not(pirate(nancy)), young(nancy))",
    "Implies(Not(toddler(nancy)), seafarer(nancy))",
