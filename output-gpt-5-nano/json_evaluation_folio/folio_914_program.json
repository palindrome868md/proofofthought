{
  "sorts": [
    {
      "name": "Person",
      "type": "DeclareSort"
    }
  ],
  "functions": [
    {
      "name": "spends_majority_on_sports",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "pro_athlete",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "Olympic_gold",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "full_time_scientist",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    },
    {
      "name": "Nobel_physics_laureate",
      "domain": [
        "Person"
      ],
      "range": "BoolSort"
    }
  ],
  "constants": {
    "persons": {
      "sort": "Person",
      "members": [
        "amy"
      ]
    }
  },
  "variables": [
    {
      "name": "p",
      "sort": "Person"
    }
  ],
  "knowledge_base": [
    "ForAll([p], Implies(pro_athlete(p), spends_majority_on_sports(p)))",
    "ForAll([p], Implies(Olympic_gold(p), pro_athlete(p)))",
    "ForAll([p], Implies(full_time_scientist(p), Not(spends_majority_on_sports(p))))",
    "ForAll([p], Implies(Nobel_physics_laureate(p), full_time_scientist(p)))",
    "Or(spends_majority_on_sports(amy), Olympic_gold(amy))",
    "Implies(Not(Nobel_physics_laureate(amy)), Not(Olympic_gold(amy)))"
  ],
  "verifications": [
    {
      "name": "Amy is neither a full-time scientist nor an Olympic gold medal winner",
      "constraint": "And(Not(full_time_scientist(amy)), Not(Olympic_gold(amy)))"
    }
  ],
  "actions": [
    "verify_conditions"
  ]
}